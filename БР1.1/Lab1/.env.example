# ------------------------------
# Application
# ------------------------------
APP_HOST=localhost
APP_PORT=8000
APP_PROTOCOL=http
APP_API_PREFIX=/api/v1

# ------------------------------
# PostgreSQL connection for API
# ------------------------------
DB_HOST=localhost
DB_PORT=15432
DB_NAME=maindb
DB_USER=maindb
DB_PASSWORD=maindb

# ------------------------------
# JWT
# ------------------------------
JWT_SECRET_KEY=super_secret_key_change_me
JWT_TOKEN_TYPE=Bearer
JWT_ACCESS_TOKEN_LIFETIME=86400

# ------------------------------
# PostgreSQL container variables (used by docker-compose)
# ------------------------------
POSTGRES_DB=maindb
POSTGRES_USER=maindb
POSTGRES_PASSWORD=maindb
